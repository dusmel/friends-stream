---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Streamio | Private Streaming Invite',
	description = 'A simple private streaming invite page for getting started with Stremio and Syncio.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth" data-font="jakarta">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-slate-950 text-slate-900 antialiased">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--page-font: 'Plus Jakarta Sans', system-ui, sans-serif;
	}

	html[data-font='inter'] {
		--page-font: 'Inter', system-ui, sans-serif;
	}

	html[data-font='jakarta'] {
		--page-font: 'Plus Jakarta Sans', system-ui, sans-serif;
	}

	html[data-font='manrope'] {
		--page-font: 'Manrope', system-ui, sans-serif;
	}

	html[data-font='sora'] {
		--page-font: 'Sora', system-ui, sans-serif;
	}

	html[data-font='space-grotesk'] {
		--page-font: 'Space Grotesk', system-ui, sans-serif;
	}

	body {
		font-family: var(--page-font);
	}
</style>

---
import LandingPage from '../components/LandingPage.astro';
import Layout from '../layouts/Layout.astro';

const stremioDownloadUrl = 'https://www.stremio.com/downloads';
const englishInviteUrl = 'https://admin.stream.hadadus.me/invite/ERWKCG';
const frenchInviteUrl = 'https://admin.stream.hadadus.me/invite/V0KWOQ';
const youtubeEmbedUrl = 'https://www.youtube.com/embed/dQw4w9WgXcQ';
const mobileMoneyNumber = '+233 55 000 0000';
const currentYear = new Date().getFullYear();
---

<Layout
	title="Hadad Private Streaming"
	description="A private streaming guide for Hadad's friends and family."
	lang="en"
>
	<LandingPage
		lang="en"
		stremioDownloadUrl={stremioDownloadUrl}
		englishInviteUrl={englishInviteUrl}
		frenchInviteUrl={frenchInviteUrl}
		youtubeEmbedUrl={youtubeEmbedUrl}
		mobileMoneyNumber={mobileMoneyNumber}
		currentYear={currentYear}
	/>
</Layout>
